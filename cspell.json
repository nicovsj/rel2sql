{
  "version": "0.2",
  "language": "en",
  "files": [
    "**/*.{js,jsx,ts,tsx,md,mdx,c,cpp,h,hpp,py,rs}"
  ],
  "exclude": [
    "**/.git/**",
    "**/node_modules/**",
    "**/bazel-*/**",
    "**/.bazelrc",
    "**/BUILD",
    "**/WORKSPACE",
    "**/MODULE.bazel",
    "**/compile_commands.json",
    "**/build.log",
    "**/bazel-*"
  ],
  "ignorePaths": [
    ".git",
    "node_modules",
    "bazel-*",
    ".bazelrc",
    "BUILD",
    "WORKSPACE",
    "MODULE.bazel",
    "compile_commands.json",
    "build.log"
  ],
  "words": [
    "bazel",
    "bzlmod",
    "isysroot",
    "mmacosx",
    "cxxopt",
    "linkopt",
    "dbg",
    "oso",
    "pwd",
    "spawn",
    "ANTLR",
    "rel2sql"
  ]
}
