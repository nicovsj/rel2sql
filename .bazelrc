# Set C++20 as the standard
build --cxxopt='-std=c++20'

# Enable platform-specific configs
build --enable_platform_specific_config

# macOS-specific configuration
build:macos --cxxopt='-isysroot/Library/Developer/CommandLineTools/SDKs/MacOSX14.5.sdk'

# Set the minimum macOS version to 10.14, otherwise ANTLR will not compile
# build --cxxopt=-mmacosx-version-min=10.14
# build --linkopt=-mmacosx-version-min=10.14

build:debug -c dbg
build:debug --features=oso_prefix_is_pwd
build:debug --spawn_strategy=local
