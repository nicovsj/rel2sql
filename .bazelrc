#--- Global C++ configuration ---

# Use C++23 standard
build --cxxopt='-std=c++23'

# Disable deprecated builtins warning
build --cxxopt='-Wno-deprecated-builtins'

#--- Warning configuration ---
# Base warnings for all builds (moderate strictness)
build --cxxopt='-Wall'
build --cxxopt='-Wextra'
build --cxxopt='-Wpedantic'

# Warnings to catch common bugs (would have caught the uninitialized arity bug!)
build --cxxopt='-Wuninitialized'
build --cxxopt='-Winit-self'  # Warn about self-initialization
build --cxxopt='-Wunused-parameter'
build --cxxopt='-Wunused-variable'
build --cxxopt='-Wunused-but-set-variable'

# Suppress warnings from external dependencies
# Match external dependency paths and disable all warnings for them
# The pattern matches files in external/ directories (Bazel's external dependency location)
build --per_file_copt='external/.*@-w'

# Suppress warnings from generated files (e.g., ANTLR-generated code in bazel-out/)
# Match bazel-out paths and disable all warnings for them
# The pattern matches files in bazel-out/ directories (Bazel's generated file location)
build --per_file_copt='bazel-out/.*@-w'

#--- Global platform-specific configuration ---

# Always apply host platform configs (e.g. build:macos). Needed so plain `bazel build`
# uses the pinned CLT SDK; otherwise Xcode's default SDK breaks Abseil C++ modules.
build --enable_platform_specific_config

# Back-compat alias (task/CI historically passed --config=default for the line above).
build:default --enable_platform_specific_config

# macOS: prefer Command Line Tools over Xcode so headers/module maps stay consistent.
# If MacOSX14.5.sdk is missing, override in user.bazelrc — see README.md "Troubleshooting".
build:macos --action_env=DEVELOPER_DIR=/Library/Developer/CommandLineTools
build:macos --cxxopt='-isysroot/Library/Developer/CommandLineTools/SDKs/MacOSX14.5.sdk'

#--- Global debug configuration ---

# Set debug configuration
build:debug --enable_platform_specific_config

build:debug -c dbg

# Enable oso_prefix_is_pwd feature
build:debug --features=oso_prefix_is_pwd
build:debug --spawn_strategy=local

# Enable local spawn strategy
build:debug --spawn_strategy=local

# Extra strict warnings for debug builds
build:debug --cxxopt='-Werror=uninitialized'  # Treat uninitialized as errors

#--- Global Emscripten configuration ---

# WASM uses Emscripten's toolchain/sysroot; do not apply build:macos -isysroot.
build:emcc --noenable_platform_specific_config

# Enable CC toolchain resolution
build:emcc --incompatible_enable_cc_toolchain_resolution

# Enable exceptions
build:emcc --features=exceptions

# Enable exceptions
build:emcc --cxxopt='-fexceptions'

# Emscripten-specific warnings (some warnings don't work well with WASM)
# Note: Emscripten uses Clang, so most warnings still apply
