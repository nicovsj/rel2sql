{
    "antlr4.generation": {
        "mode": "internal",
        "outputDir": ".",
        "language": "Cpp",
        "listeners": false,
        "visitors": true
    },
    "[cpp]": {
        "editor.tabSize": 2
    },
    "files.exclude" : {
        "**/external": true,
    },
    "search.exclude": {
        "**/bazel-*": true,
        "**/external": true,
    },
    "cSpell.words": [
        "ctes"
    ],
}
