{
    "terminal.integrated.env.osx": {
        "PATH": "/opt/homebrew/opt/llvm/bin:/usr/local/opt/llvm/bin:${env:PATH}"
    },
    "terminal.integrated.env.linux": {
        "PATH": "/usr/lib/llvm-18/bin:/usr/lib/llvm-17/bin:/usr/lib/llvm-16/bin:${env:PATH}"
    },
    "antlr4.generation": {
        "mode": "internal",
        "outputDir": ".",
        "language": "Cpp",
        "listeners": false,
        "visitors": true
    },
    "[cpp]": {
        "editor.tabSize": 2
    },
    "files.exclude": {
        "**/external": true,
        "bazel-bin": true,
        "bazel-out": true,
        "bazel-testlogs": true,
        "bazel-rel2sql": true
    },
    "search.exclude": {
        "**/bazel-*": true,
        "**/external": true,
    },
    "cSpell.words": [
        "ctes"
    ],
    "git.ignoredRepositories": [
        "_main"
    ]
}
