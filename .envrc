# RAICode dual-path correctness tests (see tests/generator/README.md).
# Requires direnv: https://direnv.net/ — run `direnv allow` once in this directory.
if [ -f third_party/raicode/Project.toml ]; then
  export JULIA_PROJECT=$PWD/third_party/raicode
  export REL2SQL_ENABLE_RAICODE=1
  export REL2SQL_REL_ENGINE_SOCKET=$PWD/.rel_engine.sock

  if command -v juliaup >/dev/null 2>&1; then
    julia_110=$(juliaup which 1.10 2>/dev/null || true)
    if [ -n "$julia_110" ]; then
      export REL2SQL_JULIA=$julia_110
    fi
  fi
fi
